---
interface Props {
  text: string;
  href: string;
  description?: string;
}

const { text, href, description } = Astro.props;
---

<section id={href} class="py-24">
  <h2
    class="mb-4 font-serif text-4xl font-bold tracking-tighter text-white md:text-5xl"
  >
    {text}
  </h2>
  {description ? (
    <p class="mb-12 max-w-2xl text-base text-neutral">
      {description}
    </p>
  ) : null}
  <slot />
</section>
