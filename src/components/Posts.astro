---
import Section from "./Section.astro";
import type { PostProps } from "@types";

interface Props {
  posts: PostProps[];
}

const { posts } = Astro.props;
---

<Section text="Stories" href="stories">
  <style>
    .post-hover-stack {
      position: absolute;
      inset: 0;
    }
    .post-hover-stack img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      opacity: 0;
      animation: postHoverCycle 4s linear infinite paused;
      transition: opacity 0.3s ease;
    }
    .group:hover .post-hover-stack img {
      animation-play-state: running;
    }
    @keyframes postHoverCycle {
      0%, 20%, 100% { opacity: 0; }
      10%, 15% { opacity: 1; }
    }
  </style>
  <div class="relative">
    <div class="relative">
      <button
        type="button"
        class="absolute left-2 top-1/2 z-20 -translate-y-1/2 rounded-full border border-white/10 bg-black/80 p-3 text-white shadow-lg shadow-black/40 transition hover:bg-white/10"
        onclick="document.getElementById('posts-scroll').scrollBy({ left: -360, behavior: 'smooth' })"
        aria-label="Scroll left"
      >
        <span class="text-lg">‹</span>
      </button>
      <button
        type="button"
        class="absolute right-2 top-1/2 z-20 -translate-y-1/2 rounded-full border border-white/10 bg-black/80 p-3 text-white shadow-lg shadow-black/40 transition hover:bg-white/10"
        onclick="document.getElementById('posts-scroll').scrollBy({ left: 360, behavior: 'smooth' })"
        aria-label="Scroll right"
      >
        <span class="text-lg">›</span>
      </button>
      <div id="posts-scroll" class="flex snap-x snap-mandatory gap-6 overflow-x-auto pb-4 pt-2 scroll-smooth scrollbar-none sm:-mx-6 sm:px-6 lg:mx-0 lg:px-0" style="-webkit-overflow-scrolling: touch;">
        {posts.map(({ title, excerpt, image, hoverImage, link, tags, date }) => (
          <article class="group snap-center min-w-[320px] max-w-[360px] shrink-0 overflow-hidden rounded-3xl border border-neutral/20 bg-[#11151f]/80 p-6 transition duration-200 hover:-translate-y-1 hover:border-primary">
            <div class="mb-5 overflow-hidden rounded-3xl border border-primary/20 bg-slate-900 shadow-2xl shadow-primary/10 transition duration-200 group-hover:shadow-[0_20px_80px_rgba(37,99,235,0.25)]">
              <div class="relative overflow-hidden">
                <img class="h-48 w-full object-cover transition duration-300 group-hover:scale-105" src={image} alt={title} />
                {hoverImage ? (
                  Array.isArray(hoverImage) ? (
                    <div class="post-hover-stack">
                      {hoverImage.map((src, index) => (
                        <img
                          class="post-hover-cycle"
                          src={src}
                          alt={`${title} hover ${index + 1}`}
                          style={`animation-delay: ${index * (4 / hoverImage.length)}s;`}
                        />
                      ))}
                    </div>
                  ) : (
                    <img
                      class="absolute inset-0 h-48 w-full object-cover opacity-0 transition duration-300 group-hover:opacity-100"
                      src={hoverImage}
                      alt={`${title} hover`}
                    />
                  )
                ) : null}
              </div>
            </div>
            <div class="mb-6 flex flex-wrap gap-2 text-[9px] uppercase tracking-[0.4em] text-primary">
              {tags.map((tag) => (
                <span class="rounded-full border border-primary/20 px-2 py-1">{tag}</span>
              ))}
            </div>
            <h3 class="mb-4 text-2xl font-semibold text-white">{title}</h3>
            <p class="mb-6 text-neutral">{excerpt}</p>
            <div class="flex items-center gap-4 text-sm text-white">
              {link ? (
                <a href={link} target="_blank" class="font-semibold text-primary hover:underline">
                  Read more
                </a>
              ) : (
                <span class="font-semibold text-neutral/70">Coming soon</span>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
    <div class="pointer-events-none absolute inset-y-0 left-0 w-12 bg-gradient-to-r from-[#0e141b]/95 to-transparent"></div>
    <div class="pointer-events-none absolute inset-y-0 right-0 w-12 bg-gradient-to-l from-[#0e141b]/95 to-transparent"></div>
  </div>
</Section>
