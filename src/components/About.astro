---
import Section from "./Section.astro";
import { Image } from "astro:assets";
import type { AboutProps, HeroProps } from "@types";

type Props = AboutProps & Pick<HeroProps, "name">;

const { description, image, name } = Astro.props;
---

<Section text="About Me" href="about">
  <div class="flex flex-col items-center gap-12 md:flex-row md:gap-8">
    <div class="space-y-6 md:max-w-xl">
      <p class="w-auto text-base text-neutral md:pr-5">{description}</p>
      <div class="flex items-center gap-2 text-sm font-medium text-neutral">
        <svg
          class="h-5 w-5 text-white"
          viewBox="0 0 24 24"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M12 2C8.13401 2 5 5.13401 5 9C5 14.25 12 22 12 22C12 22 19 14.25 19 9C19 5.13401 15.866 2 12 2Z"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
          <circle cx="12" cy="9" r="2.5" fill="currentColor" />
        </svg>
        Dubai, UAE
      </div>
      <button
        type="button"
        id="open-service-modal"
        class="inline-flex rounded-full bg-[#5755ff] px-6 py-3 text-sm font-semibold text-white transition hover:bg-[#4340d9]"
      >
        Request a service
      </button>
    </div>
    <div class="h-[22rem] w-[22rem] shrink-0 overflow-hidden rounded-full bg-transparent">
      <Image
        class="h-full w-full object-cover"
        src={image}
        width="360"
        height="360"
        alt={name}
      />
    </div>
  </div>

  <div id="service-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/70 p-4">
    <div class="w-full max-w-2xl rounded-[2rem] bg-slate-950 p-8 shadow-2xl shadow-black/50">
      <div class="mb-6 flex items-center justify-between">
        <div>
          <h3 class="text-2xl font-semibold text-white">Request a service</h3>
          <p class="text-sm text-neutral">Send your request and I will get back to you soon.</p>
        </div>
        <button
          type="button"
          id="close-service-modal"
          class="text-2xl font-bold leading-none text-white"
          aria-label="Close service request form"
        >
          ×
        </button>
      </div>
      <form id="service-request-form" class="space-y-5">
        <div class="grid gap-4 sm:grid-cols-2">
          <label class="block">
            <span class="mb-2 block text-sm font-medium text-white">Name</span>
            <input
              id="service-name"
              name="name"
              type="text"
              required
              class="w-full rounded-3xl border border-white/10 bg-slate-900 px-4 py-3 text-sm text-white outline-none transition focus:border-[#5755ff]"
            />
          </label>
          <label class="block">
            <span class="mb-2 block text-sm font-medium text-white">Mobile number</span>
            <input
              id="service-mobile"
              name="mobile"
              type="tel"
              required
              class="w-full rounded-3xl border border-white/10 bg-slate-900 px-4 py-3 text-sm text-white outline-none transition focus:border-[#5755ff]"
            />
          </label>
        </div>
        <label class="block">
          <span class="mb-2 block text-sm font-medium text-white">Service type</span>
          <select
            id="service-type"
            name="serviceType"
            required
            class="w-full rounded-3xl border border-white/10 bg-slate-900 px-4 py-3 text-sm text-white outline-none transition focus:border-[#5755ff]"
          >
            <option value="">Select service</option>
            <option value="Analytics Consulting">Analytics Consulting</option>
            <option value="BI & Analytics Solutions">BI & Analytics Solutions</option>
            <option value="BI Training & Mentorship">BI Training & Mentorship</option>
          </select>
        </label>
        <label class="block">
          <span class="mb-2 block text-sm font-medium text-white">Details (optional)</span>
          <textarea
            id="service-details"
            name="details"
            rows="4"
            class="w-full rounded-3xl border border-white/10 bg-slate-900 px-4 py-3 text-sm text-white outline-none transition focus:border-[#5755ff]"
            placeholder="Provide any additional details..."
          />
        </label>
        <button
          type="submit"
          class="inline-flex w-full justify-center rounded-full bg-[#5755ff] px-6 py-3 text-sm font-semibold text-white transition hover:bg-[#4340d9]"
        >
          Submit request
        </button>
      </form>
    </div>
  </div>

  <script type="module">
    const openModal = document.getElementById('open-service-modal');
    const closeModal = document.getElementById('close-service-modal');
    const modal = document.getElementById('service-modal');
    const form = document.getElementById('service-request-form');

    const toggleModal = (show) => {
      if (!modal) return;
      modal.classList.toggle('hidden', !show);
      modal.setAttribute('aria-hidden', show ? 'false' : 'true');
    };

    openModal?.addEventListener('click', () => toggleModal(true));
    closeModal?.addEventListener('click', () => toggleModal(false));
    modal?.addEventListener('click', (event) => {
      if (event.target === modal) toggleModal(false);
    });

    form?.addEventListener('submit', (event) => {
      event.preventDefault();
      const name = document.getElementById('service-name')?.value.trim();
      const mobile = document.getElementById('service-mobile')?.value.trim();
      const serviceType = document.getElementById('service-type')?.value;
      const details = document.getElementById('service-details')?.value.trim();

      const subject = encodeURIComponent('Service Request from Portfolio');
      const bodyLines = [
        `Name: ${name}`,
        `Mobile number: ${mobile}`,
        `Service type: ${serviceType}`,
      ];
      if (details) bodyLines.push(`Details: ${details}`);
      const body = encodeURIComponent(bodyLines.join('\n'));
      window.location.href = `mailto:Abdullahmoustafa03@gmail.com?subject=${subject}&body=${body}`;
    });
  </script>
</Section>
